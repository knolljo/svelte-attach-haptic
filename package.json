{
  "name": "svelte-attach-haptic",
  "version": "0.1.1",
  "description": "A Svelte attachment for adding haptics to elements.",
  "keywords": [
    "attachment",
    "haptics",
    "svelte",
    "svelte5"
  ],
  "homepage": "https://github.com/joknoll/svelte-attach-haptic#readme",
  "bugs": {
    "url": "https://github.com/joknoll/svelte-attach-haptic/issues"
  },
  "license": "MIT",
  "author": "joknoll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joknoll/svelte-attach-haptic.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "bumpp": "^10.4.1",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "svelte": "^5.53.11",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "svelte": ">=5.53.11"
  }
}
